# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Flask environment: development | production | default
FLASK_ENV=development

# Port the API listens on
PORT=5000

# Secret key for signing sessions and cookies.
# Generate one with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret

# Directory where uploaded audio files are stored
UPLOAD_FOLDER=uploads

# Directory where processed audio files (WAV for Whisper) are stored
PROCESSED_FOLDER=uploads/processed

# Local sample audio for raw transcription (no preprocessing)
PUBLIC_FOLDER=public

# Max upload size in bytes (default: 115343360 = 110 MiB, sized for a
# ~90 min consultation — see the comment on MAX_CONTENT_LENGTH in app/config.py)
MAX_CONTENT_LENGTH=115343360

# Enable spectral gating (noisereduce) on upload: true | false
DENOISE_ENABLED=false

# Denoise strength when DENOISE_ENABLED=true (0.0–1.0, default: 0.6)
DENOISE_PROP_DECREASE=0.6

# RNNoise voice enhancement: true | false
# Mutually exclusive with DENOISE_ENABLED — enhance_voice takes precedence if both are true
ENHANCE_VOICE_ENABLED=false

# DeepFilterNet speech enhancement: true | false
# Legacy DeepFilterNet (not in requirements.txt; pip install deepfilternet if needed)
# Mutually exclusive with DENOISE_ENABLED and ENHANCE_VOICE_ENABLED — enhance_deep takes precedence
ENHANCE_DEEP_ENABLED=false
ENHANCE_DEEP_MODEL=DeepFilterNet3
ENHANCE_DEEP_DEVICE=cpu
ENHANCE_DEEP_POST_FILTER=false
# Optional attenuation limit in dB (empty/unset = no limit)
# ENHANCE_DEEP_ATTEN_LIM_DB=

# High-pass filter (remove hum/rumble): true | false
HPF_ENABLED=false
HPF_CUTOFF_HZ=80
# Low-pass filter (reduce sibilance; effective ~7–7.5 kHz at 16 kHz sample rate): true | false
LPF_ENABLED=false
LPF_CUTOFF_HZ=7500

# Automatic gain control (dynamic volume): true | false
AGC_ENABLED=false
AGC_TARGET_DBFS=-20
AGC_MAX_GAIN_DB=12
AGC_WINDOW_MS=30

# Global loudness normalization (LUFS or peak): true | false
LOUDNESS_ENABLED=false

# Mode: lufs (ffmpeg loudnorm) | lufs_fast (pyloudnorm + constant gain) | peak
LOUDNESS_MODE=lufs

# LUFS / lufs_fast target and true-peak ceiling
LOUDNESS_TARGET_LUFS=-23
LOUDNESS_TRUE_PEAK=-1.5
# LRA only applies to ffmpeg loudnorm (lufs)
LOUDNESS_LRA=11

# Peak mode (simple max-peak scaling)
LOUDNESS_PEAK_TARGET_DBFS=-1.0

# Enable Silero VAD trim on upload: true | false
VAD_ENABLED=false

# VAD settings when VAD_ENABLED=true
VAD_THRESHOLD=0.5
VAD_MIN_SPEECH_DURATION_MS=250
VAD_MIN_SILENCE_DURATION_MS=1000
VAD_SPEECH_PAD_MS=300

# Experimental local transcription (faster-whisper) — NOT for production
WHISPER_FASTER_ENABLED=true
# VRAM guide (cuda): tiny/base ~1 GB, small ~2 GB, medium ~5 GB, large-v3 ~10 GB, distil-large-v3 ~6 GB
# Models: tiny, base, small, medium, large-v3, distil-large-v3, distil-large-v3.5, turbo, or a Hugging Face repo id
# If CUDA OOM after upload with ENHANCE_DEEP_DEVICE=cuda, use small/base or WHISPER_FASTER_DEVICE=cpu
WHISPER_FASTER_MODEL=small
WHISPER_FASTER_DEVICE=cuda
# int8_float16 fits large-v3 on ~6 GB GPUs; float16 may OOM and fall back to CPU
WHISPER_FASTER_COMPUTE_TYPE=int8_float16
WHISPER_FASTER_LANGUAGE=pt
WHISPER_FASTER_BEAM_SIZE=5
WHISPER_FASTER_INITIAL_PROMPT=Transcrição literal de consulta médica em português brasileiro. Vocabulário clínico: anticoncepcional, churrasco, colesterol, eletrocardiograma, enjoo, hipertensão, infarto, micção, mioma, tontura, abdômen, advil, antifúngico, ardência, calafrios, caminhada, camisinha, candidíase, cardiovascular, check-up, cirurgia, corrimento, diabetes, febre, ginecológico, hipertenso, hospital, internação, laboratorial, maço, meningite, nauseada, pneumonia, postinho, preservativo, pressão, preventivo, professora, ultrassom, umbigo, urinária, varizes, vômito.

# Anti-hallucination (faster-whisper defaults: compression=2.4, log_prob=-1.0, hallucination_silence=off, condition_on_previous=true)
# Stricter for long clinical audio: lower compression, higher log_prob, enable silence threshold
# WHISPER_FASTER_COMPRESSION_RATIO_THRESHOLD=2.0
# WHISPER_FASTER_LOG_PROB_THRESHOLD=-0.8
# WHISPER_FASTER_HALLUCINATION_SILENCE_THRESHOLD=2.0
# WHISPER_FASTER_CONDITION_ON_PREVIOUS_TEXT=false
# WHISPER_FASTER_VAD_FILTER=false

# Inference backend: sequential (default) or batched (BatchedInferencePipeline)
WHISPER_FASTER_INFERENCE_MODE=sequential
# WHISPER_FASTER_BATCH_SIZE=16
# WHISPER_FASTER_CHUNK_LENGTH=30

# Speaker diarization — transcribe per turn with Médico:/Paciente: labels.
# Backend is NVIDIA NeMo Sortformer (nemo_toolkit[asr] in requirements.txt).
# Word timestamps are enabled automatically during diarized transcription for speaker alignment.
DIARIZATION_ENABLED=false
DIARIZATION_BACKEND=sortformer
DIARIZATION_NUM_SPEAKERS=2
DIARIZATION_MIN_TURN_MS=400

# pyannote.audio is NOT installed (removed from requirements.txt — its
# dependency tree conflicted with nemo_toolkit's, see
# app/services/diarization_sortformer.py). DIARIZATION_BACKEND=pyannote will
# fail at runtime with "pyannote.audio is not installed" unless you
# `pip install pyannote.audio` yourself and accept the model license on
# Hugging Face (HF_TOKEN below).
# DIARIZATION_MODEL=pyannote/speaker-diarization-community-1
# DIARIZATION_DEVICE=cuda
# HF_TOKEN=

# Sortformer (nvidia/diar_sortformer_4spk-v1) config. Prior to removing
# pyannote.audio this ran via subprocess in an isolated .venv-sortformer/ to
# avoid a dependency conflict (see app/services/diarization_sortformer.py);
# now that pyannote.audio isn't installed, nemo_toolkit lives in the same
# environment as everything else and no separate venv is needed.
SORTFORMER_MODEL_ID=nvidia/diar_sortformer_4spk-v1
SORTFORMER_DEVICE=cuda
# VRAM scales much faster than linearly with audio length — empirically on a
# 6GB GPU: 5min clip ≈ 3.7GB (OK), 6min OOMs. Tune per your own GPU. Audio
# longer than this is chunked (SORTFORMER_CHUNK_S/OVERLAP_S below), not
# rejected — see diarize_wav_sortformer_chunked in diarization_sortformer.py.
SORTFORMER_MAX_DURATION_S=300
# Defaults to the same interpreter running the Flask app (sys.executable) —
# correct in Docker and in a local .venv alike, since nemo_toolkit installs
# into that same environment. Only set this if you want Sortformer to run in
# a genuinely different interpreter/environment.
# SORTFORMER_VENV_PYTHON=/path/to/python
# Chunk size/overlap for audio longer than SORTFORMER_MAX_DURATION_S. Overlap
# is used to stitch speaker identities across adjacent chunks (temporal-overlap
# matching); model was trained on ~90s sessions, so 240s chunks are untested
# beyond the empirical VRAM/coverage checks in benchmarks/results/.
SORTFORMER_CHUNK_S=240
SORTFORMER_CHUNK_OVERLAP_S=20
# Keep a persistent worker process (model loaded once in GPU memory) alive
# across requests instead of paying the ~4s NeMo import + ~1.6s model-load
# cost every call — see benchmarks/sortformer_daemon.py. Auto-starts on first
# use, auto-falls-back to the one-shot subprocess if unreachable. Safe to
# leave on; set false to force the old one-shot-per-call behavior.
SORTFORMER_USE_DAEMON=true

# LLM post-edit after Whisper (Médico/Paciente) + SOAP draft — PhiHC MedGemma (Gemma)
TRANSCRIPT_POSTPROCESS_ENABLED=false
# ASR fix (step 04) — set false to skip LLM transcript editor but keep SOAP when enabled
# ASR_FIX_ENABLED=true
TRANSCRIPT_POSTPROCESS_PROVIDER=phihc
TRANSCRIPT_POSTPROCESS_MODEL=gemma3:12b-it-qat
LLM_BASE_URL=https://api.phihc.com
LLM_API_KEY=
# LLM read timeout (seconds). ASR fix uses LLM_ASR_FIX_TIMEOUT_SECONDS (default 900).
# LLM_TIMEOUT_SECONDS=600
# LLM_ASR_FIX_TIMEOUT_SECONDS=900
# Split long ASR-fix transcripts into chunks (words per LLM call; 0 = disabled)
# ASR_FIX_CHUNK_MAX_WORDS=450
# Run chunk LLM calls in parallel (default true)
# ASR_FIX_CHUNK_PARALLEL=true
# ASR_FIX_CHUNK_MAX_WORKERS=2
# LLM_ASR_FIX_MAX_RETRIES=2
# Reject ASR-fix LLM output shorter than this fraction of input (fallback to raw transcript)
# ASR_FIX_MIN_WORD_RATIO=0.90
# ASR_FIX_MIN_SPEAKER_LINE_RATIO=0.90
# LLM_SOAP_MAX_RETRIES=0
# Fire a tiny throwaway LLM prompt in the background as soon as /transcribe starts,
# concurrently with diarization+Whisper (~17s), to pay the backend's cold-start cost
# (confirmed ~4-10s on the first call vs ~400-600ms once warm) before the first real
# LLM call needs it. Default true; only affects the first request after model idle.
# LLM_WARMUP_ENABLED=true
# Optional chart/EHR seed for SOAP (cabecalho, labs, meds not fully spoken in audio):
# SOAP_PATIENT_CHART_FILE=benchmarks/fixtures/sadie-chart-context.txt
# SOAP_PATIENT_CHART_CONTEXT=
TRANSCRIPT_POSTPROCESS_PROMPT_PATH=benchmarks/prompts/medical-transcript-editor.md
TRANSCRIPT_DIARIZATION_LABEL_PROMPT_PATH=benchmarks/prompts/medical-transcript-diarization-labels.md
# LLM step 04b: map Falante 1/2 → Médico/Paciente (default false — keep Falante labels)
# TRANSCRIPT_DIARIZATION_LABELS_ENABLED=false

# LLM step 04c: manual diarization — split plain (non-diarized) text into
# Doutor:/Paciente: turns with a single LLM call, no pyannote at all. Runs after
# ASR fix, before SOAP. Independent of DIARIZATION_ENABLED (pyannote path above).
# MANUAL_DIARIZATION_ENABLED=false
MANUAL_DIARIZATION_PROMPT_PATH=benchmarks/prompts/medical-transcript-manual-diarization.md
# Reject manual-diarization LLM output shorter than this fraction of input (fallback to plain, unlabeled text)
# MANUAL_DIARIZATION_MIN_WORD_RATIO=0.90
# SOAP draft LLM after ASR fix (set false to stop after Whisper + ASR fix)
SOAP_ENABLED=true
# SOAP: 4 LLM calls (S/O/A/P) by default; set SOAP_SPLIT_ENABLED=false for monolithic soap-draft.md
SOAP_SPLIT_ENABLED=true
# Run Subjetivo+Objetivo LLM calls in parallel (independent prompts). Default false:
# api.phihc.com's medgemma endpoint returns HTTP 502 on both when sent concurrently
# (large ~14k char prompts) — confirmed the backend can't serve 2 concurrent large
# generations for this model. Only enable if the backend is confirmed to support it.
# SOAP_PARALLEL_SUBJETIVO_OBJETIVO=false
# Strip markdown from LLM prompts (SOAP + ASR fix + diarization labels); saves tokens
# PROMPT_COMPACT=true
# SOAP_PROMPT_COMPACT=true  # deprecated alias for PROMPT_COMPACT
SOAP_PROMPTS_DIR=benchmarks/prompts
SOAP_DRAFT_PROMPT_PATH=benchmarks/prompts/soap-draft.md

# Pipeline debug logs: request/response per flow step (uploads/processed/<file_id>.pipeline/)
PIPELINE_DEBUG_LOG_ENABLED=false

# Per-step wall-clock timing for POST /upload (console logs + upload_timing.json + API field upload_timing)
UPLOAD_STEP_TIMING_ENABLED=true

# Write .pcm during upload (unused by /transcribe). Default false — saves one ffmpeg pass.
# EXPORT_PCM_ENABLED=false
