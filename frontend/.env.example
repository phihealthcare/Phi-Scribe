# Base URL of the Flask API (app/routes/audio.py).
VITE_API_BASE_URL=http://localhost:5000/api/v1/audio

# true: the SOAP/transcript panels start pre-filled with mock data
# (src/mocks/session.ts) for visual/demo purposes — no backend required.
# false: the UI starts empty/idle (no fake transcript or SOAP) and only
# ever shows real data from an actual upload or recording. Use false
# whenever you're testing against a real backend, so you don't confuse
# demo content with a real result. Uploading/recording always hits the
# real API either way — this flag only controls the *initial* seed state.
VITE_USE_MOCK=true

# 115343360 = 110 MiB, sized for a ~90 min consultation (see MAX_CONTENT_LENGTH
# comment in app/config.py) — keep in sync with the backend's MAX_CONTENT_LENGTH.
VITE_MAX_UPLOAD_BYTES=115343360

# true: log mic level, AudioContext state, and RE-03 thresholds in the browser console
# while recording (enabled automatically in `npm run dev`).
# VITE_DEBUG_AUDIO=true

# true: capture audio live via AudioWorkletNode + WebSocket
# (useRealtimeTranscription.ts) instead of the batch upload-then-transcribe
# flow — the transcript panel updates as you speak, and SOAP still only runs
# once, when you stop recording. Requires the backend's
# REALTIME_TRANSCRIPTION_ENABLED=true too (see .env.example at the repo root).
# VITE_REALTIME_TRANSCRIPTION_ENABLED=false
# VITE_REALTIME_WS_URL=ws://localhost:5000/api/v1/realtime/transcribe
